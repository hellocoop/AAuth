{
  "name": "@aauth/local-keys",
  "version": "0.7.1",
  "description": "Manage AAuth agent signing keys across hardware and software backends",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "se-helper"
  ],
  "scripts": {
    "build": "tsc",
    "build:se-helper": "bash se-helper/build.sh",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "aauth",
    "signing",
    "yubikey",
    "secure-enclave",
    "keychain"
  ],
  "author": "Dick Hardt <dick.hardt@hello.coop>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aauth-dev/packages-js",
    "directory": "local-keys"
  },
  "dependencies": {
    "@napi-rs/keyring": "^1.1.3",
    "jose": "^5.0.0"
  },
  "optionalDependencies": {
    "@aauth/hardware-keys": "^0.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
