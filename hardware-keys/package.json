{
  "name": "@aauth/hardware-keys",
  "version": "0.7.1",
  "description": "Hardware key backends for AAuth: YubiKey PIV and macOS Secure Enclave",
  "main": "index.js",
  "files": [
    "index.js",
    "index.d.ts"
  ],
  "types": "index.d.ts",
  "napi": {
    "binaryName": "hardware-keys",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc"
    ]
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aauth-dev/packages-js"
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0"
  },
  "optionalDependencies": {
    "@aauth/hardware-keys-darwin-arm64": "0.7.1",
    "@aauth/hardware-keys-darwin-x64": "0.7.1",
    "@aauth/hardware-keys-linux-x64-gnu": "0.7.1",
    "@aauth/hardware-keys-win32-x64-msvc": "0.7.1"
  }
}
