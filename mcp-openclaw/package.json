{
  "name": "@aauth/mcp-openclaw",
  "version": "0.1.1",
  "description": "OpenClaw plugin for AAuth-authenticated MCP server connections",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
