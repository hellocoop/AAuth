    "url": "https://github.com/hellocoop/AAuth",
    "directory": "mcp-openclaw"
  },
  "dependencies": {
    "@aauth/mcp-agent": "^0.1.0",
    "@aauth/local-keys": "^0.1.0",
    "@modelcontextprotocol/sdk": "^1.15.1"
